{
  "name": "@visual-node/editor-ui",
  "version": "0.0.0",
  "private": true,
  "description": "React canvas UI for building Visual Node flows: drag-and-drop nodes, connect them, preview and write generated code",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@xyflow/react": "^12.3.0",
    "zustand": "^4.5.5",
    "prism-react-renderer": "^2.4.0",
    "@uiw/react-codemirror": "^4.23.6",
    "@uiw/codemirror-theme-vscode": "^4.23.6",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-web": "^2.1.2",
    "react-window": "^1.8.10",
    "@visual-node/proto-gen": "workspace:*",
    "@visual-node/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.41",
