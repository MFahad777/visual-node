{
  "name": "visual-node",
  "version": "1.4.0",
  "description": "Visual, node-based backend builder for Node.js. Drag-and-drop flows compile to real, readable Express.js source code.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "visual-node": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MFahad777/visual-node.git"
  },
  "keywords": [
    "visual-programming",
    "node-based",
    "backend-builder",
    "code-generation",
    "express",
    "fastify",
    "flow-based-programming",
    "no-code",
    "low-code",
    "nodejs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-ui-assets.mjs && node ../../scripts/copy-examples.mjs",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-express": "^2.1.2",
    "@connectrpc/connect-node": "^2.1.2",
    "@visual-node/core": "workspace:*",
    "@visual-node/proto-gen": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}